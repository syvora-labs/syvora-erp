# ── Syvora Record Label — Environment Variables ───────────────────────────────
# For Docker:       copy to .env at the repo root   → docker compose up
# For local dev:    copy to web/.env.local           → npm run dev (from web/)
# NEVER commit either file — both are listed in .gitignore.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Find these in your Supabase project settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — used only by the admin user management page.
# Keep this secret; it bypasses Row Level Security.
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Email Module ──────────────────────────────────────────────────────────────
# Symmetric key for encrypting email passwords in the database.
# Generate with: openssl rand -hex 32
# Set the same key as a Supabase Edge Function secret:
#   supabase secrets set EMAIL_ENCRYPTION_KEY=<key>
# And expose it to the frontend for the encrypt RPC during settings save:
VITE_EMAIL_ENCRYPTION_KEY=your_encryption_key_here
