# ── Syvora Record Label — Environment Variables ───────────────────────────────
# For Docker:       copy to .env at the repo root   → docker compose up
# For local dev:    copy to web/.env.local           → npm run dev (from web/)
# NEVER commit either file — both are listed in .gitignore.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Find these in your Supabase project settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — used only by the admin user management page.
# Keep this secret; it bypasses Row Level Security.
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
